{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"paths": {
			"@oiap/cli": ["./packages/cli/src/index.ts"],
			"@oiap/core": ["./packages/core/src/index.ts"],
			"@oiap/runtime": ["./packages/runtime/src/index.ts"],
			"@oiap/exporter-antigravity": [
				"./packages/exporter-antigravity/src/index.ts"
			],
			"@oiap/exporter-cline": ["./packages/exporter-cline/src/index.ts"],
			"@oiap/exporter-codex": ["./packages/exporter-codex/src/index.ts"],
			"@oiap/exporter-cursor": ["./packages/exporter-cursor/src/index.ts"],
			"@oiap/exporter-gemini-cli": [
				"./packages/exporter-gemini-cli/src/index.ts"
			],
			"@oiap/exporter-opencode": ["./packages/exporter-opencode/src/index.ts"],
			"@oiap/exporter-vscode-copilot": [
				"./packages/exporter-vscode-copilot/src/index.ts"
			],
			"@oiap/exporter-claude-code": [
				"./packages/exporter-claude-code/src/index.ts"
			],
			"@oiap/exporter-openclaw": ["./packages/exporter-openclaw/src/index.ts"]
		},

		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	}
}
