{
	"name": "@oiap/exporter-opencode",
	"version": "0.3.0",
	"type": "module",
	"description": "OpenCode target exporter for Open Interoperable Agent Plugins.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fboldo/oiap.git",
		"directory": "packages/exporter-opencode"
	},
	"homepage": "https://github.com/fboldo/oiap#readme",
	"bugs": {
		"url": "https://github.com/fboldo/oiap/issues"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json && bun run build:hook-plugin",
		"build:hook-plugin": "bun build src/hook-plugin.ts --target=node --format=esm --outfile=dist/hook-plugin.mjs",
		"check": "bun run typecheck",
		"test": "bun run build:hook-plugin && bun test src",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@oiap/core": "workspace:*",
		"@oiap/runtime": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
