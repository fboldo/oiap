{
	"name": "@oiap/cli",
	"version": "0.0.0",
	"type": "module",
	"description": "Command-line tooling for building Open Interoperable Agent Plugin bundles.",
	"bin": {
		"oiap": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "bun run typecheck",
		"cli": "bun src/cli.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@oiap/core": "workspace:*",
		"@oiap/exporter-antigravity": "workspace:*",
		"@oiap/exporter-codex": "workspace:*",
		"@oiap/exporter-claude-code": "workspace:*",
		"@oiap/exporter-cursor": "workspace:*",
		"@oiap/exporter-openclaw": "workspace:*",
		"@oiap/exporter-vscode-copilot": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
