{
	"name": "@oiap/runtime",
	"version": "0.0.0",
	"type": "module",
	"description": "Generated runtime bridge utilities for Open Interoperable Agent Plugins.",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json && bun run build:runner",
		"build:runner": "bun build src/runner.ts --target=node --format=esm --outfile=dist/runner.mjs",
		"check": "bun run typecheck",
		"test": "bun test src",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@oiap/core": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
