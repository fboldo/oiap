{
	"name": "@oiap/exporter-vscode-copilot",
	"version": "0.0.0",
	"type": "module",
	"description": "VS Code Copilot agent plugin exporter for Open Interoperable Agent Plugins.",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "bun run typecheck",
		"test": "bun test src",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@oiap/core": "workspace:*",
		"@oiap/runtime": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
