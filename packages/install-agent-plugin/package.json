{
	"name": "install-agent-plugin",
	"version": "0.2.0",
	"type": "module",
	"description": "Consumer CLI for discovering and installing Open Interoperable Agent Plugins.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fboldo/oiap.git",
		"directory": "packages/install-agent-plugin"
	},
	"homepage": "https://github.com/fboldo/oiap#readme",
	"bugs": {
		"url": "https://github.com/fboldo/oiap/issues"
	},
	"bin": {
		"install-agent-plugin": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "bun run typecheck",
		"cli": "bun src/cli.ts",
		"test": "bun test src",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@oiap/cli": "workspace:*",
		"@oiap/core": "workspace:*"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
