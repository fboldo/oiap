{
	"name": "oiap",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.8",
	"scripts": {
		"format": "bunx biome format --write .",
		"format:check": "bunx biome format .",
		"check": "bunx biome check .",
		"typecheck": "bunx tsc -p packages/core/tsconfig.json --noEmit",
		"precommit": "bun run check && bun run typecheck",
		"prepare": "husky"
	},
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"turbo": "2.9.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
