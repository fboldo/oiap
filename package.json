{
	"name": "oiap",
	"type": "module",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fboldo/oiap.git"
	},
	"homepage": "https://github.com/fboldo/oiap#readme",
	"bugs": {
		"url": "https://github.com/fboldo/oiap/issues"
	},
	"packageManager": "bun@1.3.8",
	"scripts": {
		"build": "turbo run build",
		"format": "bunx biome format --write .",
		"format:check": "bunx biome format .",
		"check": "bunx biome check .",
		"test": "turbo run test",
		"test:coverage": "bun run build && bun test --coverage packages/core/src packages/runtime/src packages/exporter-antigravity/src packages/exporter-claude-code/src packages/exporter-codex/src packages/exporter-cursor/src packages/exporter-openclaw/src packages/exporter-vscode-copilot/src",
		"typecheck": "turbo run typecheck",
		"oiap": "bun packages/cli/src/cli.ts",
		"precommit": "bun run check && bun run typecheck && bun run test",
		"release:changed": "lerna changed",
		"release:list": "lerna list --all",
		"release:publish": "lerna publish from-package",
		"release:version": "lerna version",
		"prepare": "husky"
	},
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lerna": "^9.0.7",
		"turbo": "2.9.6"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
